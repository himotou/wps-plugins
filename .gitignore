# 依赖目录
node_modules/
dist/
build/

# 日志文件
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 运行时数据
pids
*.pid
*.seed
*.pid.lock

# 覆盖率目录
coverage/
.nyc_output/

# 编辑器目录和文件
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 环境变量文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# WPS/Office 相关临时文件 (可选，视具体开发情况而定)
*.tmp
*.temp

# TypeScript 编译输出 (如果 tsconfig.json 中指定了 outDir，通常包含在 dist 中，但也可单独忽略)
*.tsbuildinfo

# 其他常见忽略
Thumbs.db
ehthumbs.db